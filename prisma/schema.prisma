generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model School {
  id                       Int                          @id @default(autoincrement())
  name                     String
  domain                   String                       @unique
  code                     String?
  address                  String?
  city                     String?
  state                    String?
  country                  String?
  pincode                  String?
  plan                     String?
  planDurationMonths       Int?
  subscriptionStartDate    DateTime?
  subscriptionExpiryDate   DateTime?
  paymentStatus            SchoolPaymentStatus?         @default(PENDING)
  subscriptionStatus       SchoolSubscriptionStatus?    @default(PENDING)
  razorpayOrderId          String?
  razorpayPaymentId        String?
  createdAt                DateTime                     @default(now())
  deletedAt                DateTime?
  updatedAt                DateTime                     @updatedAt
  departments              Department[]
  users                    User[]
  faculty                  Faculty[]
  students                 Student[]
  subjects                 Subject[]
  semesters                Semester[]
  academicSessions         AcademicSession[]
  courseOfferings          CourseOffering[]
  facultyAssignments       FacultyAssignment[]
  studentSessionRegs       StudentSessionRegistration[]
  resultPublications       ResultPublication[]
  facultyResultSubmissions FacultyResultSubmission[]
  reappearApplications     ReappearApplication[]
  timetables               Timetable[]
  timetableSlots           TimetableSlot[]
  attendance               Attendance[]
  internalAssessments      InternalAssessment[]
  syllabi                  Syllabus[]
  gradingSystems           GradingSystem[]
  scheduleExceptions       ScheduleException[]
  facultyAbsences          FacultyAbsence[]
  absenceSubstitutions     AbsenceSubstitution[]

  @@index([subscriptionExpiryDate])
  @@map("schools")
}

model User {
  id                  Int               @id @default(autoincrement())
  schoolId            Int
  email               String            @unique
  role                Role
  name                String
  bio                 String?
  createdAt           DateTime          @default(now())
  deletedAt           DateTime?
  emailVerified       Boolean           @default(false)
  githubUrl           String?
  isActive            Boolean           @default(true)
  lastLoginAt         DateTime?
  linkedinUrl         String?
  passwordHash        String
  phoneNumber         String?
  portfolioUrl        String?
  profilePhotoUrl     String?
  updatedAt           DateTime          @updatedAt
  failedLoginAttempts Int               @default(0)
  lockedUntil         DateTime?
  school              School            @relation(fields: [schoolId], references: [id])
  student             Student?
  faculty             Faculty?
  hodOfDepartments    Department[]      @relation("DepartmentHod")
  refreshTokens       RefreshToken[]
  otpVerifications    OtpVerification[]
  auditLogs           AuditLog[]
  notifications       Notification[]

  @@index([schoolId])
  @@map("users")
}

model Department {
  id                 Int                 @id @default(autoincrement())
  schoolId           Int
  name               String
  hodUserId          Int?
  createdAt          DateTime            @default(now())
  deletedAt          DateTime?
  updatedAt          DateTime            @updatedAt
  school             School              @relation(fields: [schoolId], references: [id])
  hod                User?               @relation("DepartmentHod", fields: [hodUserId], references: [id])
  faculty            Faculty[]
  students           Student[]
  announcements      Announcement[]
  academicSessions   AcademicSession[]
  subjects           Subject[]
  scheduleExceptions ScheduleException[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([hodUserId], map: "departments_hodUserId_fkey")
  @@map("departments")
}

model Student {
  id                   Int                          @id @default(autoincrement())
  userId               Int                          @unique
  schoolId             Int
  departmentId         Int
  rollNo               String
  branch               String
  batchYear            Int
  summary              String?
  createdAt            DateTime                     @default(now())
  currentSemester      Int
  deletedAt            DateTime?
  graduationYear       Int
  isPlaced             Boolean                      @default(false)
  updatedAt            DateTime                     @updatedAt
  school               School                       @relation(fields: [schoolId], references: [id])
  department           Department                   @relation(fields: [departmentId], references: [id])
  user                 User                         @relation(fields: [userId], references: [id])
  skills               Skill[]
  projects             Project[]
  achievements         Achievement[]
  internships          Internship[]
  placements           Placement[]
  subjectMarks         SubjectMark[]
  cgpaRecords          CgpaRecord[]
  sessionRegistrations StudentSessionRegistration[]
  reappearApplications ReappearApplication[]
  attendance           Attendance[]
  internalAssessments  InternalAssessment[]

  @@unique([schoolId, rollNo])
  @@index([schoolId])
  @@index([departmentId])
  @@map("students")
}

model Faculty {
  id                       Int                       @id @default(autoincrement())
  userId                   Int                       @unique
  schoolId                 Int
  departmentId             Int
  createdAt                DateTime                  @default(now())
  deletedAt                DateTime?
  designation              String
  updatedAt                DateTime                  @updatedAt
  officeLocation           String?
  school                   School                    @relation(fields: [schoolId], references: [id])
  department               Department                @relation(fields: [departmentId], references: [id])
  user                     User                      @relation(fields: [userId], references: [id])
  achievements             Achievement[]             @relation("VerifiedBy")
  assignedReviews          AchievementReview[]       @relation("AssignedReviews")
  announcements            Announcement[]
  facultyAssignments       FacultyAssignment[]
  facultyResultSubmissions FacultyResultSubmission[]
  reappearReviews          ReappearApplication[]     @relation("ReappearReviewedBy")
  timetableSlots           TimetableSlot[]
  attendanceMarked         Attendance[]
  internalAssessments      InternalAssessment[]
  syllabi                  Syllabus[]
  absences                 FacultyAbsence[]          @relation("AbsenceOwner")
  substituteFor            AbsenceSubstitution[]     @relation("SubstituteFor")

  @@index([schoolId])
  @@index([departmentId])
  @@map("faculty")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  userId     Int
  tokenHash  String    @unique
  deviceName String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  family     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model OtpVerification {
  id        Int       @id @default(autoincrement())
  userId    Int
  email     String
  otpCode   String
  otpType   OtpType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([email])
  @@index([expiresAt])
  @@map("otp_verifications")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  ipAddress String?
  schoolId  Int?
  userAgent String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([schoolId])
  @@map("audit_logs")
}

model AcademicSession {
  id                   Int                          @id @default(autoincrement())
  schoolId             Int
  departmentId         Int
  name                 String
  academicYear         String
  semesterType         SemesterType
  startDate            DateTime
  endDate              DateTime
  status               SessionStatus                @default(upcoming)
  createdByUserId      Int
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  school               School                       @relation(fields: [schoolId], references: [id])
  department           Department                   @relation(fields: [departmentId], references: [id])
  courseOfferings      CourseOffering[]
  facultyAssignments   FacultyAssignment[]
  studentRegistrations StudentSessionRegistration[]
  resultPublications   ResultPublication[]
  reappearApplications ReappearApplication[]
  timetables           Timetable[]
  attendance           Attendance[]
  internalAssessments  InternalAssessment[]
  achievements         Achievement[]
  scheduleExceptions   ScheduleException[]
  facultyAbsences      FacultyAbsence[]

  @@index([schoolId, departmentId])
  @@index([schoolId, status])
  @@map("academic_sessions")
}

model Semester {
  id             Int           @id @default(autoincrement())
  schoolId       Int
  semesterNumber Int
  name           String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  school         School        @relation(fields: [schoolId], references: [id])
  cgpaRecords    CgpaRecord[]
  subjectMarks   SubjectMark[]

  @@unique([schoolId, semesterNumber])
  @@index([schoolId])
  @@map("semesters")
}

model Subject {
  id                       Int                       @id @default(autoincrement())
  schoolId                 Int
  name                     String
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  courseCode               String
  credits                  Int                       @default(3)
  departmentId             Int
  isActive                 Boolean                   @default(true)
  passingMarks             Float                     @default(40)
  subjectType              SubjectType               @default(theory)
  totalMarks               Float                     @default(100)
  school                   School                    @relation(fields: [schoolId], references: [id])
  department               Department                @relation(fields: [departmentId], references: [id])
  subjectMarks             SubjectMark[]
  courseOfferings          CourseOffering[]
  facultyAssignments       FacultyAssignment[]
  reappearApplications     ReappearApplication[]
  timetableSlots           TimetableSlot[]
  attendance               Attendance[]
  internalAssessments      InternalAssessment[]
  syllabus                 Syllabus?
  facultyResultSubmissions FacultyResultSubmission[]

  @@unique([departmentId, courseCode])
  @@index([schoolId])
  @@index([departmentId])
  @@map("subjects")
}

model CourseOffering {
  id             Int             @id @default(autoincrement())
  schoolId       Int
  sessionId      Int
  subjectId      Int
  departmentId   Int
  semesterNumber Int
  batchYear      Int
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  school         School          @relation(fields: [schoolId], references: [id])
  session        AcademicSession @relation(fields: [sessionId], references: [id])
  subject        Subject         @relation(fields: [subjectId], references: [id])

  @@unique([sessionId, subjectId, batchYear])
  @@index([schoolId])
  @@index([sessionId])
  @@index([subjectId])
  @@map("course_offerings")
}

model FacultyAssignment {
  id              Int             @id @default(autoincrement())
  schoolId        Int
  sessionId       Int
  facultyId       Int
  subjectId       Int
  departmentId    Int
  semesterNumber  Int
  batchYear       Int
  assignedByHodId Int
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  school          School          @relation(fields: [schoolId], references: [id])
  session         AcademicSession @relation(fields: [sessionId], references: [id])
  faculty         Faculty         @relation(fields: [facultyId], references: [id])
  subject         Subject         @relation(fields: [subjectId], references: [id])

  @@unique([sessionId, facultyId, subjectId, batchYear])
  @@index([schoolId])
  @@index([facultyId])
  @@index([sessionId])
  @@map("faculty_assignments")
}

model StudentSessionRegistration {
  id             Int                @id @default(autoincrement())
  schoolId       Int
  studentId      Int
  sessionId      Int
  semesterNumber Int
  batchYear      Int
  status         RegistrationStatus @default(active)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  school         School             @relation(fields: [schoolId], references: [id])
  student        Student            @relation(fields: [studentId], references: [id])
  session        AcademicSession    @relation(fields: [sessionId], references: [id])

  @@unique([studentId, sessionId])
  @@index([schoolId])
  @@index([studentId])
  @@index([sessionId])
  @@map("student_session_registrations")
}

model Syllabus {
  id               Int      @id @default(autoincrement())
  schoolId         Int
  subjectId        Int      @unique
  content          String   @db.LongText
  learningOutcomes String?  @db.Text
  syllabusUrl      String?
  version          Int      @default(1)
  uploadedByHodId  Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  facultyId        Int?
  school           School   @relation(fields: [schoolId], references: [id])
  subject          Subject  @relation(fields: [subjectId], references: [id])
  faculty          Faculty? @relation(fields: [facultyId], references: [id])

  @@index([schoolId])
  @@map("syllabi")
}

model SyllabusFile {
  id           Int      @id @default(autoincrement())
  schoolId     Int
  departmentId Int
  subjectId    Int
  fileUrl      String   @db.Text
  title        String?
  uploadedById Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([schoolId])
  @@index([departmentId])
  @@index([subjectId])
  @@map("syllabus_files")
}

model ResultPublication {
  id                       Int                       @id @default(autoincrement())
  schoolId                 Int
  sessionId                Int
  departmentId             Int
  batchYear                Int
  semesterNumber           Int
  status                   ResultStatus              @default(draft)
  publishedByHodId         Int?
  publishedAt              DateTime?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  school                   School                    @relation(fields: [schoolId], references: [id])
  session                  AcademicSession           @relation(fields: [sessionId], references: [id])
  facultyResultSubmissions FacultyResultSubmission[]
  subjectMarks             SubjectMark[]

  @@unique([sessionId, departmentId, batchYear, semesterNumber])
  @@index([schoolId])
  @@index([sessionId])
  @@map("result_publications")
}

model FacultyResultSubmission {
  id            Int               @id @default(autoincrement())
  schoolId      Int
  publicationId Int
  facultyId     Int
  subjectId     Int
  isSubmitted   Boolean           @default(false)
  submittedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  school        School            @relation(fields: [schoolId], references: [id])
  publication   ResultPublication @relation(fields: [publicationId], references: [id])
  faculty       Faculty           @relation(fields: [facultyId], references: [id])
  subject       Subject           @relation(fields: [subjectId], references: [id])

  @@unique([publicationId, subjectId])
  @@index([schoolId])
  @@index([publicationId])
  @@map("faculty_result_submissions")
}

model SubjectMark {
  id              Int               @id @default(autoincrement())
  studentId       Int
  semesterId      Int
  marks           Float
  createdAt       DateTime          @default(now())
  subjectId       Int
  invalidatedAt   DateTime?
  isReappear      Boolean           @default(false)
  publicationId   Int
  grade           String?
  gradePoint      Float?
  gradingSystemId Int?
  student         Student           @relation(fields: [studentId], references: [id])
  semester        Semester          @relation(fields: [semesterId], references: [id])
  subject         Subject           @relation(fields: [subjectId], references: [id])
  publication     ResultPublication @relation(fields: [publicationId], references: [id])

  @@index([studentId])
  @@index([semesterId])
  @@index([subjectId])
  @@index([publicationId])
  @@map("subject_marks")
}

model CgpaRecord {
  id               Int      @id @default(autoincrement())
  studentId        Int
  semesterId       Int
  cgpa             Float
  classAverageCgpa Float
  createdAt        DateTime @default(now())
  sgpa             Float    @default(0)
  totalCredits     Int      @default(0)
  student          Student  @relation(fields: [studentId], references: [id])
  semester         Semester @relation(fields: [semesterId], references: [id])

  @@unique([studentId, semesterId])
  @@index([studentId])
  @@index([semesterId])
  @@map("cgpa_records")
}

model ReappearApplication {
  id              Int             @id @default(autoincrement())
  schoolId        Int
  studentId       Int
  subjectId       Int
  sessionId       Int
  semesterNumber  Int
  reason          String          @db.Text
  status          ReappearStatus  @default(pending)
  hodComment      String?
  reviewedByHodId Int?
  reviewedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  school          School          @relation(fields: [schoolId], references: [id])
  student         Student         @relation(fields: [studentId], references: [id])
  subject         Subject         @relation(fields: [subjectId], references: [id])
  session         AcademicSession @relation(fields: [sessionId], references: [id])
  reviewedBy      Faculty?        @relation("ReappearReviewedBy", fields: [reviewedByHodId], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@index([sessionId])
  @@map("reappear_applications")
}

model Timetable {
  id                Int             @id @default(autoincrement())
  schoolId          Int
  sessionId         Int
  departmentId      Int
  batchYear         Int
  semesterNumber    Int
  status            TimetableStatus @default(draft)
  submittedAt       DateTime?
  approvedAt        DateTime?
  adminComment      String?
  reviewedByAdminId Int?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  school            School          @relation(fields: [schoolId], references: [id])
  session           AcademicSession @relation(fields: [sessionId], references: [id])
  slots             TimetableSlot[]

  @@unique([sessionId, departmentId, batchYear, semesterNumber])
  @@index([schoolId])
  @@index([sessionId])
  @@map("timetables")
}

model TimetableSlot {
  id                   Int                   @id @default(autoincrement())
  schoolId             Int
  timetableId          Int
  subjectId            Int
  facultyId            Int
  dayOfWeek            Int
  startTime            String
  endTime              String
  classroom            String
  slotType             SlotType              @default(lecture)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  school               School                @relation(fields: [schoolId], references: [id])
  timetable            Timetable             @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  subject              Subject               @relation(fields: [subjectId], references: [id])
  faculty              Faculty               @relation(fields: [facultyId], references: [id])
  absenceSubstitutions AbsenceSubstitution[]

  @@index([schoolId])
  @@index([timetableId])
  @@map("timetable_slots")
}

model DepartmentTimetable {
  id           Int               @id @default(autoincrement())
  schoolId     Int
  departmentId Int
  fileUrl      String            @db.Text
  uploadedById Int
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  audience     TimetableAudience
  title        String?

  @@index([schoolId])
  @@index([departmentId, audience])
  @@map("department_timetables")
}

model Attendance {
  id                Int              @id @default(autoincrement())
  schoolId          Int
  studentId         Int
  subjectId         Int
  sessionId         Int
  facultyId         Int
  date              DateTime
  status            AttendanceStatus
  markedByFacultyId Int
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  school            School           @relation(fields: [schoolId], references: [id])
  student           Student          @relation(fields: [studentId], references: [id])
  subject           Subject          @relation(fields: [subjectId], references: [id])
  session           AcademicSession  @relation(fields: [sessionId], references: [id])
  faculty           Faculty          @relation(fields: [facultyId], references: [id])

  @@unique([studentId, subjectId, sessionId, date])
  @@index([schoolId])
  @@index([studentId])
  @@index([subjectId, sessionId])
  @@map("attendance")
}

model InternalAssessment {
  id             Int             @id @default(autoincrement())
  schoolId       Int
  studentId      Int
  subjectId      Int
  sessionId      Int
  facultyId      Int
  assessmentType AssessmentType
  title          String
  marks          Float
  maxMarks       Float
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  school         School          @relation(fields: [schoolId], references: [id])
  student        Student         @relation(fields: [studentId], references: [id])
  subject        Subject         @relation(fields: [subjectId], references: [id])
  session        AcademicSession @relation(fields: [sessionId], references: [id])
  faculty        Faculty         @relation(fields: [facultyId], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@index([subjectId, sessionId])
  @@map("internal_assessments")
}

model Skill {
  id        Int        @id @default(autoincrement())
  studentId Int
  skillName String
  category  String
  createdAt DateTime   @default(now())
  level     SkillLevel
  student   Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("skills")
}

model Project {
  id          Int       @id @default(autoincrement())
  studentId   Int
  title       String
  description String?
  githubLink  String?
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  endDate     DateTime?
  liveUrl     String?
  startDate   DateTime?
  techStack   Json?
  updatedAt   DateTime  @updatedAt
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("projects")
}

model Achievement {
  id                  Int                 @id @default(autoincrement())
  studentId           Int
  verifiedBy          Int?
  title               String
  category            String
  status              AchievementStatus   @default(pending)
  rejectionReason     String?
  certificateUrl      String?
  createdAt           DateTime            @default(now())
  description         String?
  proofUrl            String?
  updatedAt           DateTime            @updatedAt
  verificationComment String?
  verifiedAt          DateTime?
  sessionId           Int?
  student             Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session             AcademicSession?    @relation(fields: [sessionId], references: [id])
  faculty             Faculty?            @relation("VerifiedBy", fields: [verifiedBy], references: [id])
  internship          Internship?
  reviews             AchievementReview[]

  @@index([studentId])
  @@index([verifiedBy], map: "achievements_verifiedBy_fkey")
  @@index([sessionId])
  @@map("achievements")
}

model AchievementReview {
  id            Int               @id @default(autoincrement())
  achievementId Int
  facultyId     Int
  status        AchievementStatus @default(pending)
  remark        String?
  reviewedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  achievement   Achievement       @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  faculty       Faculty           @relation("AssignedReviews", fields: [facultyId], references: [id])

  @@unique([achievementId, facultyId])
  @@index([achievementId])
  @@index([facultyId])
  @@map("achievement_reviews")
}

model Internship {
  id             Int          @id @default(autoincrement())
  studentId      Int
  achievementId  Int?         @unique
  companyName    String
  role           String
  certificateUrl String?
  createdAt      DateTime     @default(now())
  endDate        DateTime?
  offerLetterUrl String?
  startDate      DateTime?
  stipend        Float?
  updatedAt      DateTime     @updatedAt
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  achievement    Achievement? @relation(fields: [achievementId], references: [id])

  @@index([studentId])
  @@map("internships")
}

model Placement {
  id             Int      @id @default(autoincrement())
  studentId      Int
  companyName    String
  role           String
  packageLpa     Float
  offerLetterUrl String?
  joined         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("placements")
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int
  type      String
  message   String
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())
  link      String?
  readAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

model Announcement {
  id           Int        @id @default(autoincrement())
  facultyId    Int
  departmentId Int
  title        String
  content      String     @db.Text
  createdAt    DateTime   @default(now())
  expiresAt    DateTime?
  updatedAt    DateTime   @updatedAt
  faculty      Faculty    @relation(fields: [facultyId], references: [id])
  department   Department @relation(fields: [departmentId], references: [id])

  @@index([departmentId])
  @@index([facultyId], map: "announcements_facultyId_fkey")
  @@map("announcements")
}

model GradingSystem {
  id        Int         @id @default(autoincrement())
  schoolId  Int?
  name      String
  isDefault Boolean     @default(false)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  school    School?     @relation(fields: [schoolId], references: [id])
  rules     GradeRule[]

  @@index([schoolId])
  @@map("grading_systems")
}

model GradeRule {
  id              Int           @id @default(autoincrement())
  gradingSystemId Int
  grade           String
  gradePoint      Float
  minMarksPercent Float
  maxMarksPercent Float
  gradingSystem   GradingSystem @relation(fields: [gradingSystemId], references: [id], onDelete: Cascade)

  @@index([gradingSystemId])
  @@map("grade_rules")
}

model ScheduleException {
  id               Int             @id @default(autoincrement())
  schoolId         Int
  sessionId        Int
  departmentId     Int?
  startDate        DateTime
  endDate          DateTime
  type             ExceptionType
  scope            ExceptionScope
  startTime        String?
  endTime          String?
  reason           String
  declaredByUserId Int
  revokedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  school           School          @relation(fields: [schoolId], references: [id])
  session          AcademicSession @relation(fields: [sessionId], references: [id])
  department       Department?     @relation(fields: [departmentId], references: [id])

  @@index([departmentId])
  @@index([schoolId])
  @@index([sessionId])
  @@index([schoolId, startDate, endDate])
  @@map("schedule_exceptions")
}

model FacultyAbsence {
  id              Int                   @id @default(autoincrement())
  schoolId        Int
  sessionId       Int
  facultyId       Int
  startDate       DateTime
  endDate         DateTime
  reason          String                @db.Text
  status          AbsenceStatus         @default(pending)
  hodComment      String?
  reviewedByHodId Int?
  reviewedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  school          School                @relation(fields: [schoolId], references: [id])
  session         AcademicSession       @relation(fields: [sessionId], references: [id])
  faculty         Faculty               @relation("AbsenceOwner", fields: [facultyId], references: [id])
  substitutions   AbsenceSubstitution[]

  @@index([schoolId])
  @@index([facultyId])
  @@index([sessionId])
  @@map("faculty_absences")
}

model AbsenceSubstitution {
  id                  Int            @id @default(autoincrement())
  schoolId            Int
  absenceId           Int
  timetableSlotId     Int
  date                DateTime
  substituteFacultyId Int?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  school              School         @relation(fields: [schoolId], references: [id])
  absence             FacultyAbsence @relation(fields: [absenceId], references: [id], onDelete: Cascade)
  slot                TimetableSlot  @relation(fields: [timetableSlotId], references: [id])
  substituteFaculty   Faculty?       @relation("SubstituteFor", fields: [substituteFacultyId], references: [id])

  @@unique([absenceId, timetableSlotId, date])
  @@index([schoolId])
  @@index([absenceId])
  @@index([timetableSlotId])
  @@index([substituteFacultyId])
  @@map("absence_substitutions")
}

model PendingRegistration {
  id           Int                       @id @default(autoincrement())
  tempId       String                    @unique @default(uuid())
  schoolData   Json
  adminData    Json?
  selectedPlan String
  planAmount   Float
  status       PendingRegistrationStatus @default(school_pending)
  expiresAt    DateTime
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  // ── PHASE 8B — COUPONS (nullable, so existing rows stay valid) ──
  // Set by POST /api/registration/apply-coupon. createOrder() re-validates
  // this coupon (it may have expired between apply and pay) and recomputes
  // the discount fresh from the plan's true base price — this column is
  // just "which coupon did the user ask to apply," never a trusted amount.
  couponCode   String?

  @@index([expiresAt])
  @@map("pending_registrations")
}

model SubscriptionPlan {
  id             Int      @id @default(autoincrement())
  name           String
  durationMonths Int
  price          Float
  isCustom       Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
  @@map("subscription_plans")
}

model Payment {
  id                Int           @id @default(autoincrement())
  // PHASE 8C: tempId is now nullable — a RENEWAL payment has no
  // PendingRegistration behind it, so it sets schoolId instead and leaves
  // tempId null. Every existing/registration Payment keeps using tempId
  // exactly as before; this only widens the column to allow the new case.
  tempId            String?
  razorpayOrderId   String        @unique
  razorpayPaymentId String?
  razorpaySignature String?
  amount            Float
  currency          String        @default("INR")
  status            PaymentStatus @default(created)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  // ── PHASE 8C — SUBSCRIPTION RENEWAL (all nullable/defaulted, additive) ──
  schoolId          Int?           // set for renewals; null for registration payments
  purpose           PaymentPurpose @default(registration)
  planId            Int?           // which SubscriptionPlan this payment was for (needed by
  // the webhook path, which has no request body to read a planId from —
  // see subscription.service.js's completeRenewalForPayment)
  // ── PHASE 8E — nullable, so every Payment before this migration reads
  // back as "unknown" rather than a wrong guess. Populated going forward at
  // the moment a renewal completes (subscription.repository.js's
  // completeRenewalTransaction already computes this exact date — it just
  // never got persisted until now). This is what makes GET
  // /api/admin/subscription/history able to show "expiry became X" per past
  // renewal — School itself only ever holds the CURRENT expiry, overwritten
  // on every renewal, so without this column that history is unrecoverable
  // once a school has renewed more than once.
  resultingExpiryDate DateTime?

  @@index([tempId])
  @@index([schoolId])
  @@map("payments")
}

// ─────────────────────────────────────────────
// SCHOOL REGISTRATION + PAYMENT — PHASE 4
// One invoice per successful School registration payment. Created by the
// background "generate-invoice" job (src/jobs/invoice.processor.js), never
// inline during verify-payment — invoicing must never block or fail that request.
// ─────────────────────────────────────────────
model Invoice {
  id                Int       @id @default(autoincrement())
  schoolId          Int
  invoiceNumber     String    @unique
  amount            Float
  gst               Float     @default(0)
  totalAmount       Float
  // ── PHASE 8A — GST breakdown (all nullable so existing rows stay valid) ──
  baseAmount        Float? // pre-tax plan price
  cgstAmount        Float? // half of the GST amount (intra-state Central GST)
  sgstAmount        Float? // half of the GST amount (intra-state State GST)
  gstRate           Float? // the % rate actually applied — kept per-invoice so a
  // later GST_RATE env change doesn't silently reinterpret old invoices
  sellerGstin       String? // our company's GSTIN, from env — null if not yet configured
  // ── PHASE 8B — COUPONS (all nullable so pre-coupon invoices stay valid) ──
  couponCode         String? // the coupon code actually applied, or null
  discountAmount     Float?  // rupees knocked off the plan's base price
  originalBaseAmount Float?  // the plan's true base price BEFORE the discount
  // NOTE: `baseAmount` above keeps meaning "the base GST was computed on" —
  // when a coupon applied, that's the DISCOUNTED base, not originalBaseAmount.
  razorpayOrderId   String
  razorpayPaymentId String
  pdfPath           String?
  emailedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([schoolId])
  @@map("invoices")
}

// ─────────────────────────────────────────────
// COUPONS — PHASE 8B
// A coupon discounts a plan's BASE price; GST is then computed on the
// DISCOUNTED base (correct Indian GST treatment — tax applies to the actual
// taxable value after discount, not the pre-discount price). See
// src/modules/coupons/coupon.service.js for the math + validation rules.
// ─────────────────────────────────────────────
model Coupon {
  id          Int        @id @default(autoincrement())
  // Always stored UPPERCASE. Every lookup uppercases the caller's input
  // first (see coupon.service.js), so "save20" and "SAVE20" are the same
  // coupon — codes are case-insensitive from the user's point of view.
  code        String     @unique
  description String?
  type        CouponType
  value       Float // percentage: 0-100 meaning "% off"; fixed: flat rupee amount off
  maxUses     Int? // total redemptions allowed across ALL schools; null = unlimited
  usedCount   Int        @default(0)
  maxDiscount Float? // optional cap for percentage coupons, e.g. "20% off up to ₹2000"
  validFrom   DateTime?
  validUntil  DateTime?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("coupons")
}

enum CouponType {
  percentage
  fixed
}

// ─────────────────────────────────────────────
// SUBSCRIPTION EXPIRY REMINDERS — PHASE 8D
// One row per reminder actually sent. The @@unique below is what guarantees
// each of the 4 reminders (7/3/1 days before + once after expiry) fires
// EXACTLY once per subscription cycle — see subscription-reminder.processor.js
// for how the "insert first, then send" ordering uses this as a claim lock.
// ─────────────────────────────────────────────
model SubscriptionReminder {
  id           Int          @id @default(autoincrement())
  schoolId     Int
  reminderType ReminderType
  // The expiry THIS reminder was for — not just "when it was sent". Part of
  // the unique key so that once a renewal pushes subscriptionExpiryDate to a
  // NEW date, the old rows (tied to the OLD date) become irrelevant history
  // and this school gets a completely fresh set of 4 reminders for the new
  // cycle — nothing has to be deleted or reset for renewals to "just work".
  subscriptionExpiryDate DateTime
  sentAt       DateTime     @default(now())
  createdAt    DateTime     @default(now())

  @@unique([schoolId, reminderType, subscriptionExpiryDate])
  @@index([schoolId])
  @@map("subscription_reminders")
}

